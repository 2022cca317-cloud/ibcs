<head>
<meta charset="UTF-8" />
<title>한국 드라마 아카이브</title>
<style>
*{box-sizing:border-box}
body{
  margin:0;
  font-family:'Segoe UI', Arial, sans-serif;
  background:linear-gradient(135deg,#141e30,#243b55);
  color:white;
}
header{
  text-align:center;
  padding:40px 20px;
}
header h1{
  margin:0;
  font-size:40px;
}
header p{
  opacity:0.8;
}
.container{
  width:95%;
  max-width:1200px;
  margin:auto;
}
.year{
  margin-top:40px;
}
.year h2{
  border-left:5px solid #ffcc00;
  padding-left:10px;
}
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:20px;
  margin-top:20px;
}
.card{
  background:white;
  color:black;
  border-radius:12px;
  overflow:hidden;
  box-shadow:0 8px 20px rgba(0,0,0,0.3);
  transition:transform 0.2s;
}
.card:hover{
  transform:scale(1.05);
}
.poster{
  width:100%;
  height:260px;
  object-fit:cover;
  background:#ddd;
}
.info{
  padding:10px;
}
.title{
  font-weight:bold;
  font-size:15px;
}
.rating{
  font-size:14px;
  color:#444;
}
footer{
  text-align:center;
  padding:30px;
  opacity:0.7;
}
</style>
</head>

